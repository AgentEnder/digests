{
  "name": "pr-digest",
  "version": "1.0.0",
  "author": {
    "name": "Craigory Coppola",
    "url": "https://craigory.dev"
  },
  "bugs": {
    "url": "https://github.com/AgentEnder/digests/issues"
  },
  "homepage": "https://craigory.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentEnder/digests.git",
    "directory": "packages/pr-digest"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "pr-digest": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "cli": "node dist/cli.js",
    "prepublish": "chmod +x dist/cli.js",
    "extract-docs": "typedoc --options typedoc.json && tsx ../../scripts/extract-cli-docs.ts ./src/cli.ts --output ../../docs/cli/pr-digest --nav-section \"CLI Reference\" --nav-order 1"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "@vitest/coverage-v8": "^1.0.4",
    "eslint": "^9.15.0",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@digests/github-utils": "workspace:*",
    "@octokit/rest": "^21.0.1",
    "cli-forge": "^1.7.1",
    "markdown-factory": "^0.2.0",
    "tslib": "catalog:"
  }
}
