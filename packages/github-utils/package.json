{
  "name": "@digests/github-utils",
  "version": "1.0.0",
  "description": "Shared GitHub utilities for digest packages",
  "author": {
    "name": "Craigory Coppola",
    "url": "https://craigory.dev"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {},
  "dependencies": {
    "@digests/cache-utils": "workspace:*",
    "@octokit/rest": "^21.1.1",
    "tslib": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentEnder/digests.git",
    "directory": "packages/github-utils"
  },
  "bugs": {
    "url": "https://github.com/AgentEnder/digests/issues"
  }
}
