{
  "name": "dependency-digest",
  "version": "1.0.0",
  "description": "Scan repository dependencies and generate health digests",
  "author": {
    "name": "Craigory Coppola",
    "url": "https://craigory.dev"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "dependency-digest": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "cli": "node dist/cli.js",
    "extract-docs": "typedoc --options typedoc.json && tsx ../../scripts/extract-cli-docs.ts ./src/cli.ts --export digestCLI --output ../../docs/cli/dependency-digest --nav-section \"CLI Reference\" --nav-order 0"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@digests/cache-utils": "workspace:*",
    "@digests/github-utils": "workspace:*",
    "cli-forge": "^1.7.1",
    "isolated-workers": "^0.2.0",
    "markdown-factory": "^0.2.0",
    "tslib": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentEnder/digests.git",
    "directory": "packages/dependency-digest"
  },
  "bugs": {
    "url": "https://github.com/AgentEnder/digests/issues"
  }
}
